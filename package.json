{
  "name": "@alosha/monitor",
  "version": "0.1.0",
  "description": "Playwright-based website monitoring — checks, retries, screenshots, and alerts.",
  "keywords": ["monitor", "playwright", "uptime", "website-monitoring", "alerting", "cli"],
  "homepage": "https://monitor.alosha.dev",
  "bugs": {
    "url": "https://github.com/avlisodraude/monitor/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/avlisodraude/monitor.git"
  },
  "license": "MIT",
  "author": "Eduardo Silvanavarrete <avlis_odraude@hotmail.com>",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "monitor": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "lint": "eslint src",
    "prepare": "husky",
    "release": "npm run lint && npm run build && npm publish --access public"
  },
  "dependencies": {
    "nodemailer": "^6.9.14",
    "playwright": "^1.44.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.3.0",
    "@commitlint/config-conventional": "^19.2.2",
    "@types/node": "^20.14.0",
    "@types/nodemailer": "^6.4.15",
    "eslint": "^9.5.0",
    "husky": "^9.0.11",
    "jest": "^29.7.0",
    "lint-staged": "^15.2.7",
    "tsup": "^8.1.0",
    "typescript": "^5.4.5"
  }
}
